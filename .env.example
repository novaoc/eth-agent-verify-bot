# Discord
DISCORD_TOKEN=
# Optional: register slash commands to one guild for instant updates
GUILD_ID=
# Optional: role granted on successful agent verification
VERIFIED_ROLE_ID=

# Chain / registry (ERC-8004 Identity Registry)
# Defaults below target Base mainnet (chainId 8453). REGISTRY_ADDR must be
# set to the deployed Identity Registry on that chain.
CHAIN_ID=8453
RPC_URL=https://mainnet.base.org
REGISTRY_ADDR=

# Optional: a static HTML page that builds the EIP-712 payload and invokes
# eth_signTypedData_v4 in the user's wallet. Same role as ordinal-verify-bot's
# SIGN_PAGE_URL — leave blank to omit the convenience link.
SIGN_PAGE_URL=

# Storage
DB_PATH=verifications.db
